class Solution {
public:
    int countDigitOccurrences(vector<int>& nums, int digit) {
        int count=0;
        for(int x : nums){
            int temp=x;

            while(temp>0){
                int d=temp %10;
                if(d==digit) count++;

                temp/=10;
            }
        }
        return count;
    }
};